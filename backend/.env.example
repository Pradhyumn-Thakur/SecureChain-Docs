# Pinata Configuration
PINATA_JWT=your_pinata_jwt_token_here

# Server Configuration
PORT=3001
NODE_ENV=development

# Security
JWT_SECRET=your_secure_random_jwt_secret_here_min_32_chars
CORS_ORIGIN=http://localhost:5173

# Blockchain (access control enforcement)
# Use http://127.0.0.1:8545 and CHAIN_ID=31337 against a local hardhat node
RPC_URL=https://rpc-amoy.polygon.technology/
CONTRACT_ADDRESS=0xYourDeployedDocumentRegistryAddress
CHAIN_ID=80002

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100